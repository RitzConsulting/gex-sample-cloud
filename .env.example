# Copy to .env for LOCAL DEV ONLY. Never commit real secrets.
# In production these must come from GCP Secret Manager, not a file.

SYNC_API_KEY=dev-insecure-key-change-me
FLASK_SECRET_KEY=dev-only-flask-secret-change-me
WEBHOOK_SECRET=dev-webhook-secret-change-me
PORT=8080

# Per-IP request cap on write endpoints (defense in depth).
RATE_LIMIT_PER_MIN=60

# Leave DEBUG off. The security suite fails if stack traces leak.
# FLASK_DEBUG=0

# Comma-separated allowlist. Never use "*".
# CORS_ALLOWED_ORIGINS=
